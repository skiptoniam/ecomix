Package: ecomix
Type: Package
Title: Fitting Finite Mixture Models to Ecological Data
Version: 2.0.1
Authors@R: c(person(given = "Skipton", family = "Woolley", email = "skip.woolley@csiro.au", role = c("aut", "cre")),
             person(given = "Scott", family = "Foster", email = "scott.foster@csiro.au", role = c("aut")),
